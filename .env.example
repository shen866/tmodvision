# tModVision 管理面板 Token（必填，请设置为强密码）
AUTH_TOKEN=your-secure-token-here

# 数据目录在宿主机上的绝对路径（Docker Desktop macOS 必填）
# 用于创建 steamcmd/世界生成等临时容器时正确挂载宿主机目录。
# 示例：/Users/<用户名>/tmodvision/data
HOST_DATA_DIR=

# Steam Web API Key（可选，用于工坊搜索；没有时可通过模组 ID 安装）
# 获取地址: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# tModLoader 服务端版本，可填 GitHub Release tag 或 latest
TMOD_VERSION=v2026.04.3.0

# 容器名称与端口
TMOD_CONTAINER_NAME=tmodloader
SERVER_PORT=3000
TMOD_PORT=7777

# 首次启动时的默认服务器配置
TMOD_WORLDNAME=tModWorld
TMOD_WORLDSIZE=2
TMOD_DIFFICULTY=0
TMOD_MAXPLAYERS=8
TMOD_PASS=
TMOD_MOTD=Welcome to tModVision!
TMOD_LANGUAGE=en-US
TMOD_AUTOSAVE_INTERVAL=10
TMOD_SHUTDOWN_MESSAGE=Server is shutting down NOW!

# 首次启动时自动下载并启用的创意工坊模组 ID（逗号分隔，可选）
# TMOD_AUTODOWNLOAD=2824688072
# TMOD_ENABLEDMODS=2824688072
